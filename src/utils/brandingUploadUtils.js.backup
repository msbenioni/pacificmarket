import { getSupabase } from '../lib/supabase/client';

/**
 * Upload business branding files to Supabase Storage
 * @param {Object} params - Upload parameters
 * @param {Object} params.supabase - Supabase client
 * @param {string} params.businessId - Business ID for folder structure
 * @param {Object} params.files - Files to upload
 * @param {File} params.files.logo_file - Logo file (optional)
 * @param {File} params.files.banner_file - Banner file (optional)
 * @param {File} params.files.mobile_banner_file - Mobile banner file (optional)
 * @returns {Promise<Object>} Object with uploaded URLs
 */
export const uploadBusinessBrandingFiles = async ({ supabase, businessId, files }) => {
  const uploadedUrls = {};
  
  try {
    // Upload logo if provided
    if (files.logo_file) {
      const file = files.logo_file;
      const filePath = `logos/${businessId}-${Date.now()}-${file.name}`;
      
      const { error: uploadError } = await supabase.storage
        .from("admin-listings")
        .upload(filePath, file);
      
      if (uploadError) throw uploadError;
      
      const { data: publicUrlData } = supabase.storage
        .from("admin-listings")
        .getPublicUrl(filePath);
      
      if (publicUrlData?.publicUrl) {
        uploadedUrls.logo_url = publicUrlData.publicUrl;
      }
    }
    
    // Upload banner if provided
    if (files.banner_file) {
      const file = files.banner_file;
      const filePath = `banners/${businessId}-${Date.now()}-${file.name}`;
      
      const { error: uploadError } = await supabase.storage
        .from("admin-listings")
        .upload(filePath, file);
      
      if (uploadError) throw uploadError;
      
      const { data: publicUrlData } = supabase.storage
        .from("admin-listings")
        .getPublicUrl(filePath);
      
      if (publicUrlData?.publicUrl) {
        uploadedUrls.banner_url = publicUrlData.publicUrl;
      }
    }
    
    // Upload mobile banner if provided
    if (files.mobile_banner_file) {
      const file = files.mobile_banner_file;
      const filePath = `mobile-banners/${businessId}-${Date.now()}-${file.name}`;
      
      const { error: uploadError } = await supabase.storage
        .from("admin-listings")
        .upload(filePath, file);
      
      if (uploadError) throw uploadError;
      
      const { data: publicUrlData } = supabase.storage
        .from("admin-listings")
        .getPublicUrl(filePath);
      
      if (publicUrlData?.publicUrl) {
        uploadedUrls.mobile_banner_url = publicUrlData.publicUrl;

      if (mobileBannerError) {
        console.error('Mobile banner upload error:', mobileBannerError);
        throw new Error(`Mobile banner upload failed: ${mobileBannerError.message}`);
      }

      const { data: mobileBannerUrlData } = supabase.storage
        .from('admin-listings')
        .getPublicUrl(mobileBannerPath);

      result.mobile_banner_url = mobileBannerUrlData.publicUrl;
      console.log('Mobile banner uploaded successfully:', mobileBannerPath, result.mobile_banner_url);
    }

    console.log('All branding uploads completed:', result);
    return result;

  } catch (error) {
    console.error('Branding upload failed:', error);
    throw error;
  }
}

/**
 * Strip transient blob URLs from payload before saving to database
 * @param {Object} payload - Data payload to sanitize
 * @returns {Object} - Sanitized payload without blob URLs
 */
export function stripTransientImageUrls(payload) {
  const sanitized = { ...payload };
  
  // Remove blob URLs from image fields
  const imageFields = ['logo_url', 'banner_url', 'mobile_banner_url'];
  
  imageFields.forEach(field => {
    if (sanitized[field] && typeof sanitized[field] === 'string' && sanitized[field].startsWith('blob:')) {
      console.warn(`Stripping blob URL from ${field}:`, sanitized[field]);
      sanitized[field] = null;
    }
  });
  
  return sanitized;
}
