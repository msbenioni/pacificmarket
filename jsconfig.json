{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "./app/*", "./lib/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "next", "next/types/global"]
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "app/**/*.js", "app/**/*.jsx", "lib/**/*.js"],
  "exclude": ["node_modules", "dist", "src/vite-plugins", "src/components/ui"]
} 